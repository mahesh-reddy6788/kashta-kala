<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="#22FFFFFF"
    app:strokeWidth="1.5dp"
    app:cardBackgroundColor="@color/surface_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: Order ID and Status Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvAdminOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="#ORD-1004"
                android:textColor="@color/cream_white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAdminOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_search_view"
                android:backgroundTint="#33FFF3E0"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Pending"
                android:textColor="@color/status_pending"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Middle Content: Item thumbnail and details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#11FFFFFF"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#251E3C">

                <ImageView
                    android:id="@+id/ivAdminOrderImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_photo" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAdminOrderName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Royal Teak Bed"
                    android:textColor="@color/cream_white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAdminOrderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="15 May 2026"
                    android:textColor="@color/text_body"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAdminOrderPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 65,000"
                android:textColor="@color/amber_highlight"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/divider_light" />

        <!-- Bottom Row: Update button action -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateStatus"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:text="Update Status"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@color/amber_highlight"
                android:paddingVertical="0dp"
                android:paddingHorizontal="14dp"
                app:strokeColor="@color/amber_highlight"
                app:cornerRadius="8dp" />
        </RelativeLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
