<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="220dp"
    android:layout_marginHorizontal="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeColor="#22FFFFFF"
    app:strokeWidth="1.5dp"
    app:cardBackgroundColor="@color/surface_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivFeaturedImage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.6"
            android:scaleType="centerCrop"
            android:contentDescription="Product image" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.4"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvFeaturedName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="@color/cream_white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFeaturedMaterial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_caption"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvFeaturedPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/amber_highlight"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
