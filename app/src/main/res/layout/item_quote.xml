<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#22FFFFFF"
    app:strokeWidth="1.5dp"
    app:cardBackgroundColor="@color/surface_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Header: Name & Status Chip -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvFurnitureName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/chipStatus"
                android:layout_marginEnd="12dp"
                android:text="Premium Dining Table"
                android:textColor="@color/cream_white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_search_view"
                android:backgroundTint="#33FFB300"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Pending"
                android:textColor="@color/amber_highlight"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Subheader: Wood Grain & Dimensions -->
        <TextView
            android:id="@+id/tvWoodDimensions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Teak Wood · 6×3×2.5 ft"
            android:textColor="@color/text_body"
            android:textSize="13sp" />

        <!-- Price Estimate and Date Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvTotalEstimate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="₹ 45,000.00"
                android:textColor="@color/amber_highlight"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQuoteDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="17 May 2026"
                android:textColor="@color/text_caption"
                android:textSize="12sp" />
        </RelativeLayout>

        <!-- Dynamic Expanded Cost Breakdown -->
        <LinearLayout
            android:id="@+id/breakdownLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/background_cream"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quote Price Breakdown"
                android:textColor="@color/cream_white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBreakdownMaterial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Material: ₹35,000.00"
                android:textColor="@color/text_body"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvBreakdownDesign"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Design Fee: ₹10,000.00"
                android:textColor="@color/text_body"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvBreakdownFinish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Custom Finish: ✓"
                android:textColor="@color/text_body"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/divider_light" />

        <!-- Bottom Action Row: Delete & Share Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="end"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#FF7675" />

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_share"
                app:tint="@color/amber_highlight" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
