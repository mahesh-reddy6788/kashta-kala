<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream"
    android:paddingBottom="24dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price Quote"
            android:textColor="@color/cream_white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Pre-filled section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="From Estimator"
                        android:textColor="@color/cream_white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvEditInEstimator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️ Edit"
                        android:textColor="@color/amber_highlight"
                        android:textSize="13sp"
                        android:padding="4dp" />
                </LinearLayout>

                <TextView android:id="@+id/tvPreFillFurniture"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" android:textColor="@color/text_body" android:textSize="14sp" />
                <TextView android:id="@+id/tvPreFillWood"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textColor="@color/text_body" android:textSize="14sp" />
                <TextView android:id="@+id/tvPreFillDimensions"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textColor="@color/text_body" android:textSize="14sp" />
                <TextView android:id="@+id/tvPreFillMaterial"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textColor="@color/amber_highlight"
                    android:textSize="14sp" android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Additional charges -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Additional Charges"
                    android:textColor="@color/cream_white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Design &amp; Labour Fee (₹)"
                    app:boxStrokeColor="@color/walnut_medium"
                    app:hintTextColor="@color/walnut_medium">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDesignFee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Custom Finish Required?"
                        android:textColor="@color/text_body"
                        android:textSize="14sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCustomFinish"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/walnut_dark"
                        android:trackTint="@color/walnut_medium" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adds 15% to total when enabled"
                    android:textColor="@color/text_caption"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quote summary -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQuoteSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:strokeColor="#22FFFFFF"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="@color/surface_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:id="@+id/tvBreakdownMaterial"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/cream_white" android:textSize="13sp" android:fontFamily="monospace" />
                <TextView android:id="@+id/tvBreakdownDesign"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textColor="@color/cream_white" android:textSize="13sp" android:fontFamily="monospace" />
                <TextView android:id="@+id/tvBreakdownFinish"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textColor="@color/cream_white" android:textSize="13sp" android:fontFamily="monospace" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#55FFFFFF" android:layout_marginVertical="12dp" />

                <TextView
                    android:id="@+id/tvTotalEstimate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textColor="@color/amber_highlight"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvQuoteDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_body"
                    android:textSize="12sp"
                    android:gravity="center" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:text="Draft"
                    android:textColor="@color/amber_highlight"
                    app:chipBackgroundColor="#33FFAB40"
                    app:chipStrokeColor="@color/amber_highlight"
                    app:chipStrokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveQuote"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:text="Save Quote"
            android:textColor="@color/cream_white"
            app:backgroundTint="@color/walnut_dark"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareQuote"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Share Quote"
            android:textColor="@color/amber_highlight"
            app:strokeColor="@color/amber_highlight"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
