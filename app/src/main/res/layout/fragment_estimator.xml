<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom Estimator"
                android:textColor="@color/cream_white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"
                android:text="Enter your specifications to get an instant material cost."
                android:textColor="@color/text_body"
                android:textSize="13sp" />

            <!-- Input card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter Your Specifications"
                        android:textColor="@color/cream_white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Furniture name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFurnitureName"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Furniture Name (e.g. Corner Study Desk)"
                        app:boxStrokeColor="@color/walnut_medium"
                        app:hintTextColor="@color/walnut_medium">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFurnitureName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:imeOptions="actionNext" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Wood type dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilWoodType"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Wood Type"
                        app:boxStrokeColor="@color/walnut_medium"
                        app:hintTextColor="@color/walnut_medium">
                        <AutoCompleteTextView
                            android:id="@+id/actvWoodType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Dimensions row 1: L W H -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"
                        android:text="Dimensions"
                        android:textColor="@color/text_caption"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:hint="Length (ft)"
                            app:boxStrokeColor="@color/walnut_medium"
                            app:hintTextColor="@color/walnut_medium">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLength"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="3dp"
                            android:hint="Width (ft)"
                            app:boxStrokeColor="@color/walnut_medium"
                            app:hintTextColor="@color/walnut_medium">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etWidth"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:hint="Height (ft)"
                            app:boxStrokeColor="@color/walnut_medium"
                            app:hintTextColor="@color/walnut_medium">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etHeight"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Thickness -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Wood Thickness (inches)"
                        app:boxStrokeColor="@color/walnut_medium"
                        app:hintTextColor="@color/walnut_medium">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etThickness"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:text="1.5"
                            android:imeOptions="actionDone" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Live calculation panel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/liveCalcCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_white"
                app:strokeColor="@color/amber_highlight"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live Calculation"
                        android:textColor="@color/cream_white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView android:id="@+id/tvLiveArea"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_body" android:textSize="13sp" android:paddingVertical="3dp" />
                    <TextView android:id="@+id/tvLiveVolume"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_body" android:textSize="13sp" android:paddingVertical="3dp" />
                    <TextView android:id="@+id/tvLivePlanks"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_body" android:textSize="13sp" android:paddingVertical="3dp" />
                    <TextView android:id="@+id/tvLiveCost"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/amber_highlight" android:textSize="13sp"
                        android:textStyle="bold" android:paddingVertical="3dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Calculate button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:text="Calculate &amp; Preview"
                android:textColor="@color/cream_white"
                android:textSize="16sp"
                app:backgroundTint="@color/walnut_dark"
                app:cornerRadius="12dp" />

            <!-- Result card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_white"
                app:strokeColor="@color/amber_highlight"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estimation Report"
                        android:textColor="@color/cream_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider_light" android:layout_marginVertical="12dp" />

                    <TextView android:id="@+id/tvResultWoodType"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_body" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvResultArea"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:textColor="@color/text_body" android:textSize="13sp" />
                    <TextView android:id="@+id/tvResultVolume"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:textColor="@color/text_body" android:textSize="13sp" />
                    <TextView android:id="@+id/tvResultPlanks"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:textColor="@color/text_body" android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@color/background_cream"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvResultCost"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            android:textColor="@color/amber_highlight"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendToQuote"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="Save as Quote →"
                        android:textColor="@color/walnut_darkest"
                        app:backgroundTint="@color/amber_highlight"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
